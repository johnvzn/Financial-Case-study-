generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model CaseStudy {
  id        String     @id @default(cuid())
  title     String
  summary   String?
  status    CaseStatus @default(DRAFT)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

enum CaseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}
